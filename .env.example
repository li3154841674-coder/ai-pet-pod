# AI生成API密钥
COMFLY_API_KEY=your_comfly_api_key_here
THIRD_PARTY_API_KEY=your_third_party_api_key_here

# 虎皮椒（迅虎）V3支付配置
XUNHU_APPID=your_xunhu_appid_here
XUNHU_APPSECRET=your_xunhu_appsecret_here
XUNHU_GATEWAY=https://api.xunhupay.com/payment/do.html

# 查单（订单状态查询）接口（如果与 do.html 不同，请在这里配置）
# 示例路径请以虎皮椒官方文档为准
XUNHU_STATUS_GATEWAY=
XUNHU_QUERY_GATEWAY=

# 旧版支付配置（如需要）
PAY_APP_ID=your_pay_app_id_here
PAY_APP_SECRET=your_pay_app_secret_here

# 站点URL（部署时修改为实际域名）
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Admin Dashboard（极简密码保护）
ADMIN_SECRET_KEY=change_me_to_a_long_random_string

# Supabase（仅服务端使用 Service Role Key，切勿暴露到前端）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
